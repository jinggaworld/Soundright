# ==========================================
# SOUNDRIGHT - Environment Variables
# ==========================================
# Copy this file to .env.local and fill in your values

# ==========================================
# DATABASE
# ==========================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:pass@localhost:5432/soundright

# ==========================================
# BLOCKCHAIN - Casper TESTNET
# ==========================================
# Casper RPC endpoint (testnet)
CASPER_RPC_URL=https://rpc.testnet.casperlabs.io
CASPER_CHAIN_NAME=casper-test

# Casper oracle keys (for signing transactions)
# Generate with: casper-client keygen -o oracle
CASPER_ORACLE_PRIVATE_KEY=
CASPER_ORACLE_PUBLIC_KEY=

# Smart Contracts (set after deploying contracts to testnet)
# Get these after running: ./scripts/deploy-contracts.sh
ROYALTY_TOKEN_CONTRACT_ADDRESS=
STREAM_ORACLE_CONTRACT_ADDRESS=
DISTRIBUTOR_CONTRACT_ADDRESS=

# ==========================================
# MUSIC APIs (FREE)
# ==========================================
# Spotify API - Get at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Last.fm API - Get at: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ==========================================
# AI - Groq (FREE TIER - OpenAI compatible)
# ==========================================
# Get API key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ==========================================
# AI - NVIDIA NIM (Fallback, FREE for prototyping)
# ==========================================
# Get API key at: https://build.nvidia.com/
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# ==========================================
# APP CONFIGURATION
# ==========================================
# Session secret (generate a random string)
SESSION_SECRET=your-secret-here-change-in-production

# Admin key for accessing admin panel
# Generate a secure random string
ADMIN_KEY=your-admin-key

# Cron secret for scheduled tasks (distributions)
CRON_SECRET=your-cron-secret

# Public admin key (for client-side use)
NEXT_PUBLIC_ADMIN_KEY=your-admin-key

# ==========================================
# DEVELOPMENT
# ==========================================
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
